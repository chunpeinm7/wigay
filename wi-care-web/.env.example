# Wi-Care 系統環境變數配置範例
# 複製此檔案為 .env 並修改設定值

# 服務器端口
PORT=3000

# 認證設定
AUTH_USERNAME=admin
AUTH_PASSWORD=admin123

# 系統設定
DEVICE_NAME="Wi-Care Hub"
TIMEZONE="Asia/Taipei"

# WebSocket 設定
WS_HEARTBEAT_INTERVAL=30000

# SSE 更新頻率（毫秒）
SSE_UPDATE_INTERVAL=3000

# 日誌設定
LOG_LEVEL=info
LOG_FILE=./data/system.log

# GPIO 設定（如果使用真實硬體）
# ENABLE_REAL_GPIO=false

# MQTT 設定（可選）
# MQTT_BROKER=mqtt://localhost:1883
# MQTT_USERNAME=
# MQTT_PASSWORD=

# 資料庫設定（可選）
# DB_TYPE=sqlite
# DB_PATH=./data/wicare.db
